# ── Required ────────────────────────────────────────────────
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Server ──────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8000

# ── LLM ─────────────────────────────────────────────────────
LLM_MODEL=llama-3.1-8b-instant
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# ── GitHub ──────────────────────────────────────────────────
STALE_BRANCH_DAYS=30
MAX_FILE_SIZE_KB=500
MAX_REPO_TREE_DEPTH=4

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
